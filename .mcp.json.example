{
  "_comment": "Generate this file AFTER first Unity import. Path to mcp-unity package varies per project — find it under Library/PackageCache/com.gamelab.mcp-unity@<hash>/Server~/build/index.js. Copy this file to .mcp.json and fix the path.",
  "mcpServers": {
    "mcp-unity": {
      "command": "node",
      "args": [
        "<ABSOLUTE_PATH>/Library/PackageCache/com.gamelab.mcp-unity@<hash>/Server~/build/index.js"
      ]
    }
  }
}
